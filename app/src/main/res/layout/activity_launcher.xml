<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/desktopRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Animated wallpaper background -->
    <View
        android:id="@+id/wallpaperBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/win11_wallpaper"/>

    <!-- Vignette -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/vignette_overlay"/>

    <!-- Desktop pinned widgets area -->
    <LinearLayout
        android:id="@+id/widgetArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:gravity="end"
        android:visibility="gone"/>

    <!-- Notification toast area -->
    <FrameLayout
        android:id="@+id/notifToast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="8dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/win11_panel"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/notifIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/notifTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAM"
                    android:textSize="12sp"
                    android:textColor="#E0E0E8"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/notifText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back, Samson"
                    android:textSize="11sp"
                    android:textColor="#80C0C0D0"/>

            </LinearLayout>

            <TextView
                android:id="@+id/notifTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="now"
                android:textSize="9sp"
                android:textColor="#40C9A84C"/>

        </LinearLayout>
    </FrameLayout>

    <!-- START MENU PANEL -->
    <LinearLayout
        android:id="@+id/startMenuPanel"
        android:layout_width="match_parent"
        android:layout_height="520dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="64dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:orientation="vertical"
        android:background="@drawable/win11_panel"
        android:padding="16dp"
        android:elevation="24dp"
        android:visibility="gone">

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/win11_search_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔍  Tap here to search"
                android:textSize="13sp"
                android:textColor="#60C0C0D0"/>

        </LinearLayout>

        <!-- Pinned label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pinned"
                android:textSize="12sp"
                android:textColor="#C0C0D8"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/allAppsBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All apps ›"
                android:textSize="11sp"
                android:textColor="#80C9A84C"
                android:paddingStart="8dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/win11_btn"/>

        </LinearLayout>

        <!-- Pinned apps grid -->
        <GridView
            android:id="@+id/pinnedGrid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:numColumns="5"
            android:verticalSpacing="6dp"
            android:horizontalSpacing="4dp"
            android:stretchMode="columnWidth"
            android:listSelector="@android:color/transparent"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#20C9A84C"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- User + Power row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- User avatar -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/win11_start_btn">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="S"
                        android:textSize="16sp"
                        android:textColor="#C9A84C"
                        android:textStyle="bold"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Samson"
                    android:textSize="12sp"
                    android:textColor="#C0C0D8"
                    android:layout_marginStart="10dp"/>

            </LinearLayout>

            <!-- Power button -->
            <FrameLayout
                android:id="@+id/powerBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/win11_btn">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="⏻"
                    android:textSize="18sp"
                    android:textColor="#C9A84C"/>
            </FrameLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- ALL APPS PANEL -->
    <LinearLayout
        android:id="@+id/allAppsPanel"
        android:layout_width="match_parent"
        android:layout_height="520dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="64dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:orientation="vertical"
        android:background="@drawable/win11_panel"
        android:padding="16dp"
        android:elevation="24dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/backToStartBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹ Back"
                android:textSize="12sp"
                android:textColor="#80C9A84C"
                android:background="@drawable/win11_btn"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="All Apps"
                android:textSize="13sp"
                android:textColor="#C0C0D8"
                android:textStyle="bold"
                android:gravity="center"/>

        </LinearLayout>

        <GridView
            android:id="@+id/allAppsGrid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:numColumns="4"
            android:verticalSpacing="8dp"
            android:horizontalSpacing="4dp"
            android:stretchMode="columnWidth"
            android:listSelector="@android:color/transparent"/>

    </LinearLayout>

    <!-- TASKBAR -->
    <LinearLayout
        android:id="@+id/taskbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="@drawable/win11_taskbar"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:elevation="12dp">

        <!-- Left spacer -->
        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- Search btn -->
        <FrameLayout
            android:id="@+id/searchBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/win11_btn"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⌕"
                android:textSize="22sp"
                android:textColor="#A0A0C0"/>
        </FrameLayout>

        <!-- START button -->
        <FrameLayout
            android:id="@+id/startBtn"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/win11_start_btn"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⊞"
                android:textSize="24sp"
                android:textColor="#C9A84C"/>
        </FrameLayout>

        <!-- File manager btn -->
        <FrameLayout
            android:id="@+id/filesBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/win11_btn"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="📁"
                android:textSize="20sp"/>
        </FrameLayout>

        <!-- Browser btn -->
        <FrameLayout
            android:id="@+id/browserBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/win11_btn"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🌐"
                android:textSize="20sp"/>
        </FrameLayout>

        <!-- Camera btn -->
        <FrameLayout
            android:id="@+id/cameraBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/win11_btn"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="📷"
                android:textSize="20sp"/>
        </FrameLayout>

        <!-- Right spacer -->
        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- Clock -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/clockText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="15sp"
                android:textColor="#D0D0E8"
                android:fontFamily="sans-serif-light"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/dateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mon, Jan 1"
                android:textSize="9sp"
                android:textColor="#60A0A0C0"/>

        </LinearLayout>

        <!-- Chevron / show more -->
        <FrameLayout
            android:id="@+id/chevronBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/win11_btn">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="∧"
                android:textSize="14sp"
                android:textColor="#60A0A0C0"/>
        </FrameLayout>

    </LinearLayout>

</FrameLayout>
